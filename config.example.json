{
  "gateway": {
    "port": 4000,
    "heartbeatIntervalMs": 15000,
    "heartbeatTimeoutMs": 5000
  },
  "agents": [
    {
      "id": "主控",
      "name": "主控助手",
      "feishu": {
        "appId": "cli_xxxxxxxxxxxx",
        "appSecret": "YOUR_FEISHU_APP_SECRET"
      },
      "claude": {
        "apiKey": "sk-ant-YOUR_API_KEY",
        "baseUrl": "https://api.anthropic.com",
        "model": "claude-opus-4-6",
        "systemPrompt": "你是主控助手，负责协调和管理各子助手。",
        "maxTokens": 2048,
        "historyLimit": 20
      },
      "access": {
        "dmPolicy": "open",
        "groupPolicy": "open",
        "requireMention": true,
        "respondToMentionAll": false,
        "allowFrom": [],
        "denyFrom": []
      },
      "behavior": {
        "replyMode": "text",
        "chunkSize": 4000,
        "typingIndicator": true,
        "persistHistory": false
      },
      "subAgents": [
        {
          "id": "助手A",
          "name": "助手A",
          "feishu": {
            "appId": "cli_yyyyyyyyyyyy",
            "appSecret": "YOUR_SUB_AGENT_APP_SECRET"
          },
          "claude": {
            "apiKey": "sk-ant-YOUR_API_KEY",
            "baseUrl": "https://api.anthropic.com",
            "model": "claude-sonnet-4-6",
            "systemPrompt": "你是一个专业、友好的助手，请用简洁的语言回答问题。",
            "maxTokens": 2048,
            "historyLimit": 20
          },
          "access": {
            "dmPolicy": "open",
            "groupPolicy": "open",
            "requireMention": true
          },
          "behavior": {
            "replyMode": "text",
            "persistHistory": false
          }
        }
      ]
    }
  ]
}
